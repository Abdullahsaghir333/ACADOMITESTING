PORT=4000
MONGODB_URI=

# Required for auth (use a long random string in development)
JWT_SECRET=

# Google AI — optional when using local Ollama for most text; still used for: audio transcription,
# podcast script generation (Python service), and image text when IMAGE_TEXT_BACKEND=gemini.
GEMINI_API_KEY=
# Optional override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# LLM routing (Node API). gemini = all text via Gemini. ollama = local models via Ollama.
# LLM_BACKEND=gemini
# LLM_BACKEND=ollama
# OLLAMA_HOST=http://127.0.0.1:11434
# Tutor slides / live Q&A / ELI5 — default llama2
# OLLAMA_MODEL_TUTOR=llama2
# Notes, bookmarks, recap chat — default phi3:mini
# OLLAMA_MODEL_LIGHT=phi3:mini
# Role-reversal JSON, cheat sheets — default phi3
# OLLAMA_MODEL_STRUCTURED=phi3
# Image text: tesseract (offline OCR), ollama (llava), or gemini
# IMAGE_TEXT_BACKEND=tesseract

# CORS — your Next.js origin
FRONTEND_URL=http://localhost:3000

# Python podcast microservice (Gemini + gTTS)
PODCAST_SERVICE_URL=http://127.0.0.1:5001

# Python tutor microservice (gTTS + MediaPipe focus) — slides/Q&A use Gemini on this API
TUTOR_SERVICE_URL=http://127.0.0.1:5002
