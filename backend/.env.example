PORT=4000
MONGODB_URI=

# Required for auth (use a long random string in development)
JWT_SECRET=

# Google AI — **only** for image/audio extraction (uploads), mic transcription, and podcast script (Python).
# All other text (tutor, notes, bookmarks, cheat sheets, role reversal) uses Ollama (Llama 2 / Phi-3 / Phi-3 Mini).
GEMINI_API_KEY=
# Optional override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Ollama — required for tutor / study notes / bookmarks / cheat sheets / role reversal (Node API).
# OLLAMA_HOST=http://127.0.0.1:11434
# Tutor slides / live Q&A / ELI5 — default llama2
# OLLAMA_MODEL_TUTOR=llama2
# Notes, bookmarks, recap chat — default phi3:mini
# OLLAMA_MODEL_LIGHT=phi3:mini
# Role-reversal JSON, cheat sheets — default phi3
# OLLAMA_MODEL_STRUCTURED=phi3

# CORS — your Next.js origin
FRONTEND_URL=http://localhost:3000

# Python podcast microservice (Gemini dialogue script + audio)
PODCAST_SERVICE_URL=http://127.0.0.1:5001

# Python tutor microservice (Edge TTS + MediaPipe focus)
TUTOR_SERVICE_URL=http://127.0.0.1:5002
