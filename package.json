{
  "name": "acadomi",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Powered Personalized Learning Platform (FYP)",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:podcast": "python/services/podcast/.venv/Scripts/python.exe python/services/podcast/app.py",
    "dev:tutor": "python/services/tutor/.venv/Scripts/python.exe -m uvicorn app:app --host 127.0.0.1 --port 5002 --app-dir python/services/tutor",
    "build": "npm run build --workspace=frontend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "lint": "npm run lint --workspace=frontend"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "mongodb": "^7.1.1"
  }
}
